<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wall Panel Pro - Minimalist Template</title>
    <style>
        /* --- Reset & Core Variables --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        :root {
            --bg-main: #111214;
            --bg-card: #1c1e22;
            --bg-sidebar: #18191b;
            --text-primary: #e3e4e6;
            --text-muted: #9ba0a6;
            --status-red: #8a2024;
            --status-red-border: #e53935;
            --status-blue: #1c3d5a;
            --status-blue-border: #3182ce;
            --status-yellow: #d69e2e;
            --accent-blue: #4299e1;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-primary);
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* --- Sidebar Navigation --- */
        aside {
            width: 60px;
            background-color: var(--bg-sidebar);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 15px 0;
            border-right: 1px solid #2d3139;
            justify-content: space-between;
        }

        .nav-icons {
            display: flex;
            flex-direction: column;
            gap: 20px;
            width: 100%;
            align-items: center;
        }

        .icon-btn {
            width: 40px;
            height: 40px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            cursor: pointer;
        }

        .icon-btn.active {
            color: var(--accent-blue);
            background-color: #232d38;
        }

        .profile-circle {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            background-color: #4a5568;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 14px;
        }

        /* --- Main Dashboard Layout --- */
        main {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 15px;
            gap: 15px;
            overflow-y: auto;
        }

        /* Top Header Bar */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 18px;
            font-weight: 600;
            padding-bottom: 5px;
        }

        /* Critical Banner */
        .alert-banner {
            background-color: var(--status-red);
            border: 1px solid var(--status-red-border);
            border-radius: 12px;
            padding: 14px 20px;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Grid Layouts */
        .metrics-row {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 12px;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 1.2fr 0.8fr;
            gap: 15px;
            flex: 1;
        }

        .column {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .button-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
            gap: 10px;
        }

        /* --- UI Component Cards --- */
        .card {
            background-color: var(--bg-card);
            border-radius: 12px;
            padding: 12px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .metric-card {
            padding: 15px;
            flex-direction: row;
            align-items: center;
            justify-content: flex-start;
            gap: 15px;
        }

        .metric-value {
            font-size: 18px;
            font-weight: bold;
        }

        .metric-label {
            font-size: 11px;
            color: var(--text-muted);
            text-transform: uppercase;
        }

        .tile {
            background-color: var(--bg-card);
            border-radius: 10px;
            padding: 15px 10px;
            text-align: center;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            border: 1px solid transparent;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }

        .tile-sub {
            font-size: 10px;
            color: var(--text-muted);
        }

        /* State Variations */
        .tile.active-blue {
            background-color: var(--status-blue);
            border-color: var(--status-blue-border);
        }

        .tile.active-yellow {
            background-color: #4a3b12;
            border-color: var(--status-yellow);
        }

        .tile.active-red {
            background-color: var(--status-red);
            border-color: var(--status-red-border);
        }

        /* Camera Feed Placeholders */
        .camera-card {
            padding: 0;
            position: relative;
            overflow: hidden;
            background: #2d3139;
            aspect-ratio: 16 / 10;
            border-radius: 12px;
        }

        .camera-feed {
            width: 100%;
            height: 100%;
            background: linear-gradient(45deg, #1e222b, #2d3139);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            font-size: 14px;
        }

        .camera-timestamp {
            position: absolute;
            top: 8px;
            left: 8px;
            background: rgba(0,0,0,0.6);
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 10px;
        }

        /* Weather Panel */
        .weather-card {
            background: linear-gradient(135deg, #1a2a3a, #141c24);
            padding: 20px;
        }

        /* People Row */
        .people-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
        }

        .person-badge {
            background-color: var(--bg-card);
            border-radius: 20px;
            padding: 6px 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            border: 1px solid #2d3139;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            background-color: #48bb78;
            border-radius: 50%;
        }

        /* --- Footer Status Bar --- */
        footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 5px 10px;
            font-size: 13px;
            color: var(--text-muted);
            border-top: 1px solid #2d3139;
            margin-top: auto;
        }

        .footer-left {
            font-weight: bold;
            color: var(--text-primary);
        }
    </style>
</head>
<body>

    <aside>
        <div class="nav-icons">
            <div class="icon-btn">☰</div>
            <div class="icon-btn active">🎛️</div>
            <div class="icon-btn">🖥️</div>
            <div class="icon-btn">📹</div>
            <div class="icon-btn">⚙️</div>
        </div>
        <div class="profile-circle">W</div>
    </aside>

    <main>
        <header>
            <div>Wall Panel Pro</div>
            <div style="font-size: 16px; color: var(--text-muted);">🔍 💬</div>
        </header>

        <div class="alert-banner">
            <span>🔓</span> Garage Lock Unlocked
        </div>

        <div class="metrics-row">
            <div class="card metric-card">
                <span style="font-size: 24px; color: #48bb78;">🍃</span>
                <div>
                    <div class="metric-label">AQI</div>
                    <div class="metric-value">26</div>
                </div>
            </div>
            <div class="card metric-card">
                <span style="font-size: 24px; color: #4299e1;">🏠</span>
                <div>
                    <div class="metric-label">Indoor</div>
                    <div class="metric-value">66.7 °F</div>
                </div>
            </div>
            <div class="card metric-card">
                <span style="font-size: 24px; color: #ecc94b;">⚡</span>
                <div>
                    <div class="metric-label">Power</div>
                    <div class="metric-value">4,197 W</div>
                </div>
            </div>
            <div class="card metric-card">
                <span style="font-size: 24px; color: #ecc94b;">☀️</span>
                <div>
                    <div class="metric-label">Lux</div>
                    <div class="metric-value">2,771 lx</div>
                </div>
            </div>
            <div class="card metric-card">
                <span style="font-size: 24px; color: #48bb78;">🔋</span>
                <div>
                    <div class="metric-label">Tablet</div>
                    <div class="metric-value">100%</div>
                </div>
            </div>
        </div>

        <div class="dashboard-grid">
            
            <div class="column">
                <div>
                    <div class="section-title">Security</div>
                    <div class="button-grid">
                        <div class="tile active-blue">🚪 <span>Front</span></div>
                        <div class="tile">🚪 <span>Kitchen</span></div>
                        <div class="tile active-blue">🪟 <span>Slider</span></div>
                        <div class="tile">🏠 <span>Shed</span></div>
                        <div class="tile">🚪 <span>Man Door</span></div>
                        <div class="tile">🚘 <span>Garage</span></div>
                        <div class="tile active-blue">🐔 <span>Chicken</span></div>
                        <div class="tile active-red">🔒 <span>Lock</span></div>
                    </div>
                </div>

                <div class="camera-card">
                    <div class="camera-timestamp">Doorbell • Live</div>
                    <div class="camera-feed">[ Porch Cam Feed ]</div>
                </div>
            </div>

            <div class="column">
                <div>
                    <div class="section-title">Lights</div>
                    <div class="button-grid" style="grid-template-columns: repeat(3, 1fr);">
                        <div class="tile">💡 <span>Porch</span></div>
                        <div class="tile">💡 <span>Entry</span></div>
                        <div class="tile active-yellow">🍳 <span>Kitchen</span><span class="tile-sub">On</span></div>
                        <div class="tile">🛋️ <span>Living</span></div>
                        <div class="tile">🍽️ <span>Dining</span></div>
                        <div class="tile">🛋️ <span>Table</span></div>
                        <div class="tile">🏮 <span>Patio</span></div>
                        <div class="tile">🔥 <span>Fire Pit</span></div>
                        <div class="tile active-yellow">💡 <span>Hallway</span><span class="tile-sub">76%</span></div>
                        <div class="tile">🌿 <span>Backyard</span></div>
                        <div class="tile">🚘 <span>Garage</span></div>
                        <div class="tile">🔒 <span>Lock Light</span></div>
                        <div class="tile">🛋️ <span>North Lamp</span></div>
                        <div class="tile">🛋️ <span>South Lamp</span></div>
                        <div class="tile">🌲 <span>Tree</span></div>
                    </div>
                </div>

                <div class="camera-card">
                    <div class="camera-timestamp">Driveway • Live</div>
                    <div class="camera-feed">[ Driveway Cam Feed ]</div>
                </div>
            </div>

            <div class="column">
                <div class="card weather-card">
                    <div style="font-size: 14px; color: var(--text-muted);">Partly cloudy</div>
                    <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 5px;">45% Humidity</div>
                    <div style="font-size: 44px; font-weight: 300; margin-bottom: 10px;">70°F</div>
                    <div style="font-size: 12px; display: flex; flex-direction: column; gap: 6px;">
                        <div style="display: flex; justify-content: space-between;"><span>Tue</span><span>56° / 70°</span></div>
                        <div style="display: flex; justify-content: space-between;"><span>Wed</span><span>52° / 74°</span></div>
                        <div style="display: flex; justify-content: space-between;"><span>Thu</span><span>51° / 76°</span></div>
                        <div style="display: flex; justify-content: space-between;"><span>Fri</span><span>55° / 79°</span></div>
                    </div>
                </div>

                <div>
                    <div class="section-title">Actions</div>
                    <div class="button-grid" style="grid-template-columns: repeat(3, 1fr);">
                        <div class="tile">🏠 <span style="font-size: 11px;">Home</span></div>
                        <div class="tile">🌙 <span style="font-size: 11px;">Good Night</span></div>
                        <div class="tile">🛑 <span style="font-size: 11px;">All Off</span></div>
                    </div>
                </div>
            </div>
        </div>

        <div>
            <div class="section-title" style="font-size: 16px; margin-bottom: 8px;">People</div>
            <div class="people-row">
                <div class="person-badge"><div class="status-dot"></div> Brad (Home)</div>
                <div class="person-badge"><div class="status-dot"></div> Brigette (Home)</div>
                <div class="person-badge"><div class="status-dot" style="background-color: #718096;"></div> Member 3</div>
                <div class="person-badge"><div class="status-dot" style="background-color: #718096;"></div> Member 4</div>
            </div>
        </div>

        <footer>
            <div class="footer-left">🕒 6:09 PM</div>
            <div>💧 45% · 🌅 Sunrise 4:51 AM · 🌇 Sunset 8:55 PM</div>
        </footer>
    </main>

</body>
</html>
